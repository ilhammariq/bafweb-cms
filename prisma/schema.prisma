generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model teams {
  id            String          @id @db.Uuid
  team_name     String          @db.VarChar(25)
  team_desc     String?
  is_active     Boolean?        @default(true)
  usr_crt       String?         @db.Uuid
  usr_upd       String?         @db.Uuid
  dtm_crt       DateTime        @default(now()) @db.Timestamp(6)
  dtm_upd       DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  teams_members teams_members[]
}

model members {
  id            String          @id @db.Uuid
  member_name   String          @db.VarChar(25)
  member_email  String          @unique @db.VarChar(50)
  avatar        String?         @db.VarChar(255)
  is_active     Boolean?        @default(true)
  usr_crt       String?         @db.Uuid
  usr_upd       String?         @db.Uuid
  dtm_crt       DateTime        @default(now()) @db.Timestamp(6)
  dtm_upd       DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  role          String          @db.VarChar(25)
  avatar_index  Int?
  teams_members teams_members[]
  user_access   user_access?
  event_participants  event_participants[]
}

model teams_members {
  id        String   @id @db.Uuid
  team_id   String   @db.Uuid
  member_id String   @db.Uuid
  is_active Boolean? @default(true)
  usr_crt   String?  @db.Uuid
  usr_upd   String?  @db.Uuid
  dtm_crt   DateTime @default(now()) @db.Timestamp(6)
  dtm_upd   DateTime @default(now()) @updatedAt @db.Timestamp(6)
  member    members  @relation(fields: [member_id], references: [id], onDelete: Cascade)
  team      teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([team_id, member_id])
}

model general_setting_type {
  id                        String             @id @db.Uuid
  general_setting_type_code String             @unique @db.VarChar(25)
  general_setting_type_desc String             @db.VarChar(255)
  is_active                 Boolean?           @default(true)
  usr_crt                   String?            @db.Uuid
  usr_upd                   String?            @db.Uuid
  dtm_crt                   DateTime           @default(now()) @db.Timestamp(6)
  dtm_upd                   DateTime           @default(now()) @updatedAt @db.Timestamp(6)

  general_settings          general_setting[]
}

model general_setting {
  id                        String   @id @db.Uuid
  general_setting_type_code String   @db.VarChar(25)
  general_setting_code      String   @db.VarChar(25)
  general_setting_desc      String   @db.VarChar(255)
  is_active                 Boolean? @default(true)
  usr_crt                   String?  @db.Uuid
  usr_upd                   String?  @db.Uuid
  dtm_crt                   DateTime @default(now()) @db.Timestamp(6)
  dtm_upd                   DateTime @default(now()) @updatedAt @db.Timestamp(6)

  general_setting_type      general_setting_type @relation(fields: [general_setting_type_code], references: [general_setting_type_code])

  @@unique([general_setting_type_code, general_setting_code])
}

model events {
  id            String          @id @db.Uuid
  event_title   String          @db.VarChar(255)
  event_desc    String?           
  category_code String          @db.VarChar(25)
  location      String          @db.VarChar(255)
  latitude      Decimal?        @db.Decimal(9, 6)
  longitude     Decimal?        @db.Decimal(9, 6)
  is_active     Boolean?        @default(true)
  usr_crt       String?         @db.Uuid
  usr_upd       String?         @db.Uuid
  dtm_crt       DateTime        @default(now()) @db.Timestamp(6)
  dtm_upd       DateTime        @default(now()) @updatedAt @db.Timestamp(6)

  event_sessions event_sessions[]
  event_participants  event_participants[]
}

model event_sessions {
  id         String   @id @db.Uuid
  event_id   String   @db.Uuid
  event_date DateTime @db.Date
  start_time DateTime @db.Time(6)
  end_time   DateTime? @db.Time(6)
  is_active  Boolean? @default(true)
  usr_crt    String?  @db.Uuid
  usr_upd    String?  @db.Uuid
  dtm_crt    DateTime @default(now()) @db.Timestamp(6)
  dtm_upd    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  event      events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model user_access {
  id                String    @id @db.Uuid
  member_id         String    @db.Uuid
  password          String    @db.VarChar(255)
  role_access       String    @db.VarChar(25)
  last_login        DateTime? @db.Timestamp(6)
  is_active         Boolean?  @default(true)
  usr_crt           String?   @db.Uuid
  usr_upd           String?   @db.Uuid
  dtm_crt           DateTime  @default(now()) @db.Timestamp(6)
  dtm_upd           DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  member            members   @relation(fields: [member_id], references: [id])

  @@unique([member_id])
}

model event_participants {
  id         String   @id @db.Uuid
  event_id   String   @db.Uuid
  member_id  String   @db.Uuid
  status_code String   @db.VarChar(25)
  is_active  Boolean? @default(true)
  usr_crt    String?  @db.Uuid
  usr_upd    String?  @db.Uuid
  dtm_crt    DateTime @default(now()) @db.Timestamp(6)
  dtm_upd    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  event      events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  member     members  @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([event_id, member_id])
}